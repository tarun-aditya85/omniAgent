# Database
DATABASE_URL=postgresql+asyncpg://omnigrowth:omnigrowth_dev_pass@localhost:5432/omnigrowth_db

# Redis
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=your_secret_key_here_change_in_production
JWT_SECRET_KEY=your_jwt_secret_key_here_change_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Encryption (for storing DSP credentials)
ENCRYPTION_KEY=your_32_byte_encryption_key_base64_encoded

# Environment
ENVIRONMENT=development
LOG_LEVEL=info

# CORS
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Frontend API URL
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# Google Ads (for connector)
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=

# Meta Ads (for connector)
META_APP_ID=
META_APP_SECRET=

# OpenAI (for AI Copilot)
OPENAI_API_KEY=

# Anthropic Claude (alternative for AI Copilot)
ANTHROPIC_API_KEY=
